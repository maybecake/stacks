FROM ubuntu:24.04

# Create the user that VS Code is looking for
ARG USERNAME=devcontainer
ARG USER_UID=1000
ARG USER_GID=$USER_UID

RUN if ! getent group $USER_GID; then groupadd --gid $USER_GID $USERNAME; fi \
    && if ! getent passwd $USER_UID; then \
    useradd --uid $USER_UID --gid $USER_GID -m $USERNAME; \
    else \
    EXISTING=$(getent passwd $USER_UID | cut -d: -f1) \
    && usermod -l $USERNAME -d /home/$USERNAME -m $EXISTING \
    && groupmod -n $USERNAME $EXISTING 2>/dev/null || true; \
    fi \
    && apt-get update \
    && apt-get install -y sudo \
    && echo $USERNAME ALL=\(root\) NOPASSWD:ALL > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# Install base dependencies
# (Removed the duplicate 'sudo' from your list)
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    wget \
    git \
    unzip \
    vim \
    tmux \
    python3 \
    protobuf-compiler \
    ca-certificates \
    zsh \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 23 and enable corepack (run as root)
RUN curl -fsSL https://deb.nodesource.com/setup_23.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g npm@latest \
    && corepack enable \
    && corepack prepare pnpm@latest --activate

# --- Switch to devcontainer user for user-space configs ---
USER $USERNAME
WORKDIR /home/$USERNAME

# Set up environment for pnpm and go
ENV PNPM_HOME="/home/$USERNAME/.local/share/pnpm"
ENV PATH="$PATH:/home/$USERNAME/go/bin:$PNPM_HOME"
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0

# Create pnpm directory so it has the correct permissions before the volume mounts
RUN mkdir -p $PNPM_HOME

# Install Oh My Zsh AS the devcontainer user, not root
RUN sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

# Configure zsh shell profile
RUN cat >> /home/devcontainer/.zshrc <<'EOF'

# Export paths for pnpm and Go
export PNPM_HOME="/home/devcontainer/.local/share/pnpm"
export PATH="$PATH:/home/devcontainer/go/bin:$PNPM_HOME"

# Welcome message for dev docker container
echo "🐳 Welcome to stacks dev docker container"

# Customize prompt to indicate Docker environmen
ZSH_THEME="clean"
PROMPT='🐳 %F{blue}%c%f/ $(git_prompt_info)%F{white}❯%f '
EOF
# RUN sed -i 's/\r$//' /home/devcontainer/.zshrc

CMD ["/bin/zsh"]