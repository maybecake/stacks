FROM ubuntu:24.04

# Create the user that VS Code is looking for
ARG USERNAME=devcontainer
ARG USER_UID=1000
ARG USER_GID=$USER_UID

RUN if ! getent group $USER_GID; then groupadd --gid $USER_GID $USERNAME; fi \
    && if ! getent passwd $USER_UID; then \
    useradd --uid $USER_UID --gid $USER_GID -m $USERNAME; \
    else \
    EXISTING=$(getent passwd $USER_UID | cut -d: -f1) \
    && usermod -l $USERNAME -d /home/$USERNAME -m $EXISTING \
    && groupmod -n $USERNAME $EXISTING 2>/dev/null || true; \
    fi \
    && apt-get update \
    && apt-get install -y sudo \
    && echo $USERNAME ALL=\(root\) NOPASSWD:ALL > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

# Set up environment for pnpm
ENV PNPM_HOME="/home/devcontainer/.local/share/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN mkdir -p $PNPM_HOME
RUN chown -R devcontainer:devcontainer /home/devcontainer
# Prevent Corepack from asking for confirmation when downloading binaries
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
# Add pnpm to the zsh shell profile for the devcontainer user
RUN echo 'export PNPM_HOME="/home/devcontainer/.local/share/pnpm"' >> /home/devcontainer/.zshrc \
    && echo 'export PATH="$PNPM_HOME:$PATH"' >> /home/devcontainer/.zshrc

ENV PATH="/home/devcontainer/go/bin:$PATH"

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    wget \
    git \
    unzip \
    vim \
    python3 \
    protobuf-compiler \
    ca-certificates \
    zsh \
    sudo \
    && sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended \
    && chsh -s $(which zsh) devcontainer \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 23 and enable pnpm via corepack


RUN curl -fsSL https://deb.nodesource.com/setup_23.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g npm@latest \
    && corepack enable \
    && corepack prepare pnpm@latest --activate

RUN pnpm add -g @anthropic-ai/claude-code @fission-ai/openspec@latest

USER devcontainer
WORKDIR /home/devcontainer
CMD ["/bin/zsh"]
