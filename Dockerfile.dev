FROM ubuntu:24.04

# Create the user that VS Code is looking for
ARG USERNAME=devcontainer
ARG USER_UID=1000
ARG USER_GID=$USER_UID

RUN if ! getent group $USER_GID; then groupadd --gid $USER_GID $USERNAME; fi \
    && if ! getent passwd $USER_UID; then \
        useradd --uid $USER_UID --gid $USER_GID -m $USERNAME; \
    else \
        EXISTING=$(getent passwd $USER_UID | cut -d: -f1) \
        && usermod -l $USERNAME -d /home/$USERNAME -m $EXISTING \
        && groupmod -n $USERNAME $EXISTING 2>/dev/null || true; \
    fi \
    && apt-get update \
    && apt-get install -y sudo \
    && echo $USERNAME ALL=\(root\) NOPASSWD:ALL > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    wget \
    git \
    unzip \
    vim \
    python3 \
    protobuf-compiler \
    ca-certificates \
    sudo \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 23
RUN curl -fsSL https://deb.nodesource.com/setup_23.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g npm@latest pnpm

USER devcontainer
WORKDIR /home/devcontainer
CMD ["/bin/bash"]