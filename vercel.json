{
  "framework": "vite",
  "installCommand": "pnpm install && pnpm install --prefix frontend && frontend/node_modules/.bin/buf generate",
  "buildCommand": "cd frontend && pnpm build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/adam.hello.HelloService/:path*", "destination": "/api/hello" },
    { "source": "/adam.yo.YoService/:path*", "destination": "/api/yo" },
    { "source": "/adam.sup.SupService/:path*", "destination": "/api/sup" }
  ]
}
