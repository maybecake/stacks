{
  "framework": "vite",
  "installCommand": "pnpm install && pnpm install --prefix frontend && frontend/node_modules/.bin/buf generate",
  "devCommand": "cd frontend && pnpm dev --port $PORT",
  "buildCommand": "pnpm db:migrate && cd frontend && pnpm build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/hello.HelloService/:path*", "destination": "/api/hello" },
    { "source": "/yo.YoService/:path*", "destination": "/api/yo" },
    { "source": "/sup.SupService/:path*", "destination": "/api/sup" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
